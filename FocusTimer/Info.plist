<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 화면에 보이는 앱 이름 (앱 전환기/알림 등) -->
    <key>CFBundleName</key>
    <string>Daily Punchclock</string>
    <key>CFBundleDisplayName</key>
    <string>Daily Punchclock</string>

    <!-- 앱의 고유 식별자 (회사/본인.앱이름 형태) -->
    <key>CFBundleIdentifier</key>
    <string>com.tony.FocusTimer</string>

    <!-- 실제 실행될 파일 이름 (Contents/MacOS/ 안의 파일명과 같아야 함) -->
    <key>CFBundleExecutable</key>
    <string>FocusTimer</string>

    <!-- 아이콘 파일 (Resources/AppIcon.icns) -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- 최소 macOS 버전 -->
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>

    <!-- LSUIElement = true → Dock 아이콘 없이 '메뉴바 전용 앱'으로 시작.
         (대시보드 창을 열 때만 잠깐 일반 앱처럼 전환했다가 닫으면 다시 숨어요) -->
    <key>LSUIElement</key>
    <true/>

    <!-- 위치 권한 안내 문구 ('현재 위치 찍기'를 누를 때 한 번 물어봐요) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>공부한 장소를 기록에 함께 남기기 위해 현재 위치를 사용해요.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
</dict>
</plist>
